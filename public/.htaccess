<IfModule mod_headers.c>
  <FilesMatch "\.json$">
    Header set Content-Type "application/json; charset=utf-8"
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, POST, OPTIONS"
    Header set Access-Control-Allow-Headers "Content-Type"
    Header set Cache-Control "no-cache, max-age=0"
  </FilesMatch>
</IfModule>

<IfModule mod_authz_core.c>
  # Make root JSON files public even if parent auth is enabled.
  <FilesMatch "^(data|price)\.json$">
    Require all granted
  </FilesMatch>
</IfModule>

<IfModule mod_auth_basic.c>
  # Disable inherited Basic Auth for these public JSON files.
  <FilesMatch "^(data|price)\.json$">
    AuthType None
    Require all granted
  </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Convenience aliases for ESP32 firmware
  RewriteRule ^api/price/?$ /api/price.json [L,NC]
  RewriteRule ^api/data/?$ /api/data.json [L,NC]

  # Do not route API and .json files to SPA index
  RewriteCond %{REQUEST_URI} ^/api/ [OR]
  RewriteCond %{REQUEST_URI} \.json$
  RewriteRule ^ - [L]

  # SPA fallback
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

