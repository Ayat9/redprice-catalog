# PostgreSQL для Prisma (локально или облако)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/redprice?schema=public"

# CMS новостей: один и тот же ключ на сервере и в Vite (запись в production)
# В dev можно не задавать — запись разрешена без ключа (только NODE_ENV !== production)
NEWS_WRITE_KEY=""
VITE_NEWS_WRITE_KEY=""

# AI автоответчик техподдержки инвестора
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
